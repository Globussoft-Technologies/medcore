# ── Core ─────────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/medcore?schema=public"
JWT_SECRET="your-super-secret-jwt-key-change-this"
JWT_REFRESH_SECRET="your-refresh-token-secret-change-this"
PORT=4000
CORS_ORIGIN="http://localhost:3000"
NODE_ENV="development"
# Human-readable hospital name used in AI-generated referral / discharge
# letters and other patient-facing copy. Falls back to "MedCore Hospital".
# HOSPITAL_NAME="MedCore Hospital & Diagnostics"

# ── Test DB (vitest integration suite) ───────────────────────────────────────
# Isolated Postgres URL used by `apps/api/src/test/setup.ts#resetDB`. Must be
# a different database to DATABASE_URL — integration tests `db push --force-reset`
# on every suite. Unset = integration suites are silently skipped.
# DATABASE_URL_TEST="postgresql://postgres:postgres@localhost:5432/medcore_test?schema=public"

# ── Rate limiting ────────────────────────────────────────────────────────────
# When set to "true", the global and per-route rate limiters become no-ops.
# Useful for load tests; never set in production.
# DISABLE_RATE_LIMITS=false

# ── AI (Sarvam AI — India-region, DPDP-compliant) ────────────────────────────
# Get your API key at https://dashboard.sarvam.ai/
SARVAM_API_KEY="sk-..."
# Opt-in: run live-Sarvam eval suites against the real API instead of the
# recorded fixtures. Costs real money — only enable in manual eval runs.
# SARVAM_LIVE_TEST=false

# ── AI multi-provider router (GAP-P5) ────────────────────────────────────────
# MedCore routes all LLM calls through apps/api/src/services/ai/model-router.ts.
# Default provider is Sarvam (India-region, DPDP-compliant). Set AI_PROVIDER to
# `openai` or `anthropic` to swap backends fleet-wide without touching code.
# `anthropic` is stubbed — see model-router.ts for the re-add path.
AI_PROVIDER="sarvam"

# OpenAI (fallback / non-India deployments)
# OPENAI_API_KEY=sk-...
# OPENAI_BASE_URL=https://api.openai.com/v1    # optional override (Azure, etc.)

# Anthropic (requires re-adding @anthropic-ai/sdk — see model-router.ts docstring)
# ANTHROPIC_API_KEY=sk-ant-...

# ── ASR provider (speech-to-text) ────────────────────────────────────────────
# Sarvam is the default — fast, India-region, DPDP-compliant, but does NOT
# produce per-speaker (diarization) labels. Set ASR_PROVIDER=assemblyai for
# true acoustic speaker detection at the cost of latency + cost + data leaving
# India region. `deepgram` is stubbed (see asr-providers.ts for the re-add path).
ASR_PROVIDER="sarvam"

# AssemblyAI — required when ASR_PROVIDER=assemblyai. https://www.assemblyai.com/
# ASSEMBLYAI_API_KEY=<assemblyai api key>

# Deepgram — not yet implemented. Reserved for future enablement.
# DEEPGRAM_API_KEY=<deepgram api key>

# ── Notifications ─────────────────────────────────────────────────────────────
# WhatsApp — Meta Cloud API
# WHATSAPP_API_KEY=<Meta access token>
# WHATSAPP_API_URL=https://graph.facebook.com/v17.0/<PHONE_NUMBER_ID>/messages

# SMS — MSG91 (recommended for India)
# SMS_API_KEY=<MSG91 authkey>
# SMS_API_URL=https://control.msg91.com/api/v5/sms
# SMS_PROVIDER=msg91
# SMS_SENDER_ID=MEDCOR

# SMS — Generic JSON provider (Twilio-compatible, etc.)
# SMS_API_KEY=<API key>
# SMS_API_URL=<provider endpoint>

# Email — SendGrid
# EMAIL_API_KEY=<SendGrid API key>
# EMAIL_API_URL=https://api.sendgrid.com/v3/mail/send
# EMAIL_FROM=noreply@yourhospital.com

# Push — Expo Push Service (no credentials needed for basic delivery)
# EXPO_ACCESS_TOKEN=<Expo account token, optional for enhanced throughput>

# ── File Storage ──────────────────────────────────────────────────────────────
# Local disk (default — no extra config needed)
UPLOAD_SIGNING_SECRET="change-this-to-a-random-secret"

# AWS S3 (set STORAGE_PROVIDER=s3 to activate)
# STORAGE_PROVIDER=s3
# AWS_REGION=ap-south-1
# AWS_S3_BUCKET=medcore-uploads
# AWS_ACCESS_KEY_ID=<IAM key>
# AWS_SECRET_ACCESS_KEY=<IAM secret>
# AWS_S3_ENDPOINT=   # optional: Cloudflare R2 / MinIO endpoint

# ── Payments ──────────────────────────────────────────────────────────────────
# RAZORPAY_KEY_ID=rzp_live_...
# RAZORPAY_KEY_SECRET=...

# ── Telemedicine (Jitsi Meet) ────────────────────────────────────────────────
# Leave all three unset to use the public https://meet.jit.si with unsigned
# rooms (development / demo). For production, set JITSI_DOMAIN to your
# self-hosted or JaaS domain and configure the JWT-signing app.
JITSI_DOMAIN="meet.jit.si"
# JITSI_APP_ID=<JaaS app id or prosody app_id>
# JITSI_APP_SECRET=<shared secret — HS256>

# ── Insurance TPA Claims ──────────────────────────────────────────────────────
# Credentials for each Third-Party Administrator. Each TPA requires partner
# on-boarding — only set the keys for TPAs your hospital is actually connected
# to. Adapters fall back to AUTH_FAILED when their env pair is missing.

# Medi Assist — https://api.mediassist.in/docs
# TPA_MEDIASSIST_API_KEY=<issued by Medi Assist partner portal>
# TPA_MEDIASSIST_HOSPITAL_ID=<your hospital provider id on their network>
# TPA_MEDIASSIST_API_URL=https://api.mediassist.in  # optional override

# Paramount Health Services — provider-support@paramounttpa.com
# TPA_PARAMOUNT_API_KEY=<HMAC signing key>
# TPA_PARAMOUNT_CLIENT_CODE=<hospital client code>
# TPA_PARAMOUNT_API_URL=https://api.paramounttpa.com  # optional override

# Vidal Health
# TPA_VIDAL_API_KEY=
# TPA_VIDAL_PROVIDER_ID=

# FHPL (Family Health Plan Ltd)
# TPA_FHPL_API_KEY=
# TPA_FHPL_PROVIDER_ID=

# ICICI Lombard General Insurance
# TPA_ICICI_LOMBARD_API_KEY=
# TPA_ICICI_LOMBARD_AGENT_CODE=

# Star Health & Allied Insurance
# TPA_STAR_HEALTH_API_KEY=
# TPA_STAR_HEALTH_HOSPITAL_CODE=

# ── Monitoring ────────────────────────────────────────────────────────────────
# SENTRY_DSN=https://...@sentry.io/...

# ── CRM webhook (marketing enquiry mirror) ───────────────────────────────────
# When set, each new marketing enquiry is POSTed to this URL so an external
# CRM (HubSpot, Zoho, Salesforce) can pick it up. Leave unset to disable.
# CRM_WEBHOOK_URL=https://hooks.example.com/medcore

# ── AI feature tuning (optional) ─────────────────────────────────────────────
# AI Claims denial predictor: set to any value enables the LLM review pass
# on top of the rule engine. Costs an extra Sarvam call per predict.
# AI_DENIAL_LLM=1
# AI roster store path — JSON snapshot for the shift-planner's learned
# preferences. Defaults to a temp path; override for prod persistence.
# AI_ROSTER_STORE_PATH=/var/lib/medcore/roster-store.json
# No-show predictor weights: override the default rule-engine weights via a
# JSON file on disk. See services/ai/no-show.ts for the expected shape.
# NOSHOW_WEIGHTS_PATH=/etc/medcore/noshow-weights.json

# ── HL7 v2 inbound (MLLP) ────────────────────────────────────────────────────
# Cap inbound HL7 messages/min/sender. Unset = use the built-in default.
# HL7_RATE_LIMIT=60

# ── Fraud detector tuning (optional) ─────────────────────────────────────────
# All of these override sensible defaults in services/ai/fraud.ts.
# FRAUD_HIGH_FREQ_INVOICE_COUNT=20      # invoices/day to flag as unusual
# FRAUD_LARGE_DISCOUNT_ABS=10000        # absolute discount amount (INR)
# FRAUD_LARGE_DISCOUNT_PCT=0.5          # fraction of invoice total
# FRAUD_LARGE_REFUND_ABS=5000
# FRAUD_PRESCRIPTION_SIGMA_K=3          # stddevs from per-doctor baseline

# ── ABDM / ABHA (Ayushman Bharat Digital Mission) ─────────────────────────────
# Register your HIP/HIU at https://sandbox.abdm.gov.in to obtain credentials.
# ABDM_CLIENT_ID=<gateway client id>
# ABDM_CLIENT_SECRET=<gateway client secret>
# ABDM_BASE_URL=https://dev.abdm.gov.in
# ABDM_GATEWAY_URL=https://dev.abdm.gov.in/gateway
# ABDM_CM_ID=sbx   # Consent Manager id; "sbx" for sandbox, "ndhm" for prod
# ABDM_JWKS_URL=   # optional override; default ${ABDM_BASE_URL}/gateway/v0.5/certs
# ABDM_SKIP_VERIFY=false  # dev-only: when true, webhook callbacks with
#                         # missing/invalid signatures are allowed through
#                         # (audited + logged). NEVER enable in production.
