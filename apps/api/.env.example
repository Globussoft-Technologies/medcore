# ── Core ─────────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/medcore?schema=public"
JWT_SECRET="your-super-secret-jwt-key-change-this"
JWT_REFRESH_SECRET="your-refresh-token-secret-change-this"
PORT=4000
CORS_ORIGIN="http://localhost:3000"
NODE_ENV="development"

# ── AI (Sarvam AI — India-region, DPDP-compliant) ────────────────────────────
# Get your API key at https://dashboard.sarvam.ai/
SARVAM_API_KEY="sk-..."

# ── Notifications ─────────────────────────────────────────────────────────────
# WhatsApp — Meta Cloud API
# WHATSAPP_API_KEY=<Meta access token>
# WHATSAPP_API_URL=https://graph.facebook.com/v17.0/<PHONE_NUMBER_ID>/messages

# SMS — MSG91 (recommended for India)
# SMS_API_KEY=<MSG91 authkey>
# SMS_API_URL=https://control.msg91.com/api/v5/sms
# SMS_PROVIDER=msg91
# SMS_SENDER_ID=MEDCOR

# SMS — Generic JSON provider (Twilio-compatible, etc.)
# SMS_API_KEY=<API key>
# SMS_API_URL=<provider endpoint>

# Email — SendGrid
# EMAIL_API_KEY=<SendGrid API key>
# EMAIL_API_URL=https://api.sendgrid.com/v3/mail/send
# EMAIL_FROM=noreply@yourhospital.com

# Push — Expo Push Service (no credentials needed for basic delivery)
# EXPO_ACCESS_TOKEN=<Expo account token, optional for enhanced throughput>

# ── File Storage ──────────────────────────────────────────────────────────────
# Local disk (default — no extra config needed)
UPLOAD_SIGNING_SECRET="change-this-to-a-random-secret"

# AWS S3 (set STORAGE_PROVIDER=s3 to activate)
# STORAGE_PROVIDER=s3
# AWS_REGION=ap-south-1
# AWS_S3_BUCKET=medcore-uploads
# AWS_ACCESS_KEY_ID=<IAM key>
# AWS_SECRET_ACCESS_KEY=<IAM secret>
# AWS_S3_ENDPOINT=   # optional: Cloudflare R2 / MinIO endpoint

# ── Payments ──────────────────────────────────────────────────────────────────
# RAZORPAY_KEY_ID=rzp_live_...
# RAZORPAY_KEY_SECRET=...

# ── Monitoring ────────────────────────────────────────────────────────────────
# SENTRY_DSN=https://...@sentry.io/...
